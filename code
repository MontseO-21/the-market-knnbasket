    "articulos_frecuentes = apriori(basket_filtrado, min_support=0.03,\n",
    "                              use_colnames = True).sort_values('support', ascending = False).reset_index(drop= True)\n",
    "#lambda x: len(x): calcula la longitud del conjunto, es decir, cuántos artículos contien\n",
    "articulos_frecuentes['lenght'] = articulos_frecuentes['itemsets'].apply(lambda x:len(x))\n",
    "articulos_frecuentes"
   ]
